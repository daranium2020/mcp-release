  "dependencies": {
    "@mcp-launch/core": "workspace:*",
    "@mcp-launch/reporter": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
