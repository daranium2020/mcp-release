{
  "name": "@mcp-launch/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "mcp-launch": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
