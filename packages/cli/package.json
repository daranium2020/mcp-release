{
  "name": "@mcp-release/cli",
  "version": "0.1.1",
  "description": "Release validation CLI for MCP servers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daranium2020/mcp-release.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "validation",
    "release",
    "cli"
  ],
  "main": "./dist/index.js",
  "bin": {
    "mcp-release": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@mcp-release/core": "workspace:*",
    "@mcp-release/reporter": "workspace:*",
    "@types/node": "^22.0.0",
    "commander": "^12.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
